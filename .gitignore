# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# build logs & debug screenshots (root-level clutter)
*.log
/cb_*.png
/logcat*.txt

# machine-specific Norton TLS trust store (regenerable; see build notes)
/comeback-cacerts

# design reference images (not app code)
/IMG_*.png
